# ─── Facebook ──────────────────────────────────────────────────────────────────
FACEBOOK_EMAIL=your_email@example.com
FACEBOOK_PASSWORD=your_password_here
COOKIES_FILE=cookies.json

# ─── OpenRouter ────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MODEL_NAME=google/gemini-flash-1.5
TEMPERATURE=0.7
MAX_TOKENS=1000
MAX_CONTEXT_MESSAGES=10

# ─── Bot ───────────────────────────────────────────────────────────────────────
BOT_NAME=@MyAI

# Danh sách Group ID được phép (JSON array hoặc phân cách bằng dấu phẩy)
# Ví dụ: ["1234567890", "9876543210"]
# Để trống = cho phép tất cả group
GROUP_IDS=[]

# Danh sách User ID được chat riêng (optional, để trống = không ai được DM)
ALLOWED_USER_IDS=[]

# ─── Discord ───────────────────────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxx/yyyy

# ─── Reconnect ─────────────────────────────────────────────────────────────────
# Số giây chờ trước khi thử reconnect
RECONNECT_DELAY=10
# Số lần tối đa thử reconnect (0 = vô hạn)
MAX_RECONNECT_ATTEMPTS=0
